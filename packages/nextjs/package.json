{
  "name": "@lightning-ecommerce/nextjs",
  "version": "0.1.0",
  "description": "Next.js integration for lightning-ecommerce: route handler, React hooks, and checkout UI",
  "license": "MIT",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "require": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./server/route": {
      "react-server": "./dist/server/route.mjs",
      "import": "./dist/server/route.mjs",
      "require": "./dist/server/route.js",
      "types": "./dist/server/route.d.ts"
    },
    "./server": {
      "react-server": "./dist/server/index.mjs",
      "import": "./dist/server/index.mjs",
      "require": "./dist/server/index.js",
      "types": "./dist/server/index.d.ts"
    }
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "peerDependencies": {
    "next": ">=14",
    "react": ">=18",
    "react-dom": ">=18"
  },
  "dependencies": {
    "@lightning-ecommerce/core": "workspace:*",
    "server-only": "^0.0.1"
  },
  "devDependencies": {
    "@types/react": "^18.3.0",
    "typescript": "^5.7.0",
    "tsup": "^8.3.0",
    "vitest": "^2.1.0"
  }
}
