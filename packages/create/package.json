{
  "name": "@lightning-ecommerce/create",
  "version": "0.1.0",
  "description": "CLI scaffold tool — run once to wire lightning-ecommerce into your Next.js project",
  "license": "MIT",
  "bin": {
    "create-lightning-ecommerce": "./dist/index.js"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": ["dist"],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@clack/prompts": "^0.9.0",
    "@lightning-ecommerce/core": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "typescript": "^5.7.0",
    "tsup": "^8.3.0",
    "vitest": "^2.1.0"
  },
  "engines": {
    "node": ">=18"
  }
}
